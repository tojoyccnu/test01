import { clsx, type ClassValue } from 'clsx';
import { twMerge } from 'tailwind-merge';

/**
 * 合并和条件渲染 Tailwind 类名
 * 
 * @param inputs - 类名数组，支持字符串、对象、数组、条件表达式
 * @returns 合并后的类名字符串
 * 
 * @example
 * cn('px-2 py-1', 'bg-primary-6')
 * // => 'px-2 py-1 bg-primary-6'
 * 
 * @example
 * cn('px-2 py-1', isActive && 'bg-primary-6')
 * // => 'px-2 py-1 bg-primary-6' (if isActive is true)
 * // => 'px-2 py-1' (if isActive is false)
 * 
 * @example
 * cn('px-2', { 'py-1': true, 'py-2': false })
 * // => 'px-2 py-1'
 */
export function cn(...inputs: ClassValue[]) {
  return twMerge(clsx(inputs));
}
